# Copy to `.env` next to app.py (not committed). systemd on EC2 loads this via EnvironmentFile.

# Required for signed sessions (use a long random string in production, especially if login is enabled).
# SECRET_KEY=

# Optional: turn off debug in production
# FLASK_DEBUG=0

# Default DB (dev): asset-register/data/asset_register.sqlite
# Production (matches Terraform backup cron):
# DATABASE_PATH=/opt/asset-register/data/asset_register.sqlite

# --- Login (optional) ---
# If ASSET_REGISTER_AUTH_USER is set AND you set either ASSET_REGISTER_AUTH_PASSWORD
# or ASSET_REGISTER_AUTH_PASSWORD_HASH, the app and /api/* require a session login.
# Leave ASSET_REGISTER_AUTH_USER unset to keep the app open (no login).

# ASSET_REGISTER_AUTH_USER=admin
# ASSET_REGISTER_AUTH_PASSWORD=change-me

# Recommended for production: store a hash instead of plain text:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
# ASSET_REGISTER_AUTH_PASSWORD_HASH=pbkdf2:sha256:...
