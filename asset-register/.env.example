# Optional: copy to `.env` next to app.py (not committed).
# On EC2, the systemd unit sets DATABASE_PATH; you can override here.

# SECRET_KEY=generate-a-long-random-string
# FLASK_DEBUG=0

# Default DB is asset-register/data/asset_register.sqlite (dev).
# Production (matches Terraform backup cron):
# DATABASE_PATH=/opt/asset-register/data/asset_register.sqlite

# Bind port is configured in systemd / deploy, not Flask dev server.
