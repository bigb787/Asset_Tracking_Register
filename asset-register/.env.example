# Copy to .env and set values. Required unless you use AUTH_DISABLED (local dev only).
ASSET_REGISTER_AUTH_USER=admin
ASSET_REGISTER_AUTH_PASSWORD=your-secure-password

# Optional: bcrypt-style hash instead of plain password (do not set both).
# ASSET_REGISTER_AUTH_PASSWORD_HASH=pbkdf2:sha256:...

# Local development only — never in production:
# ASSET_REGISTER_AUTH_DISABLED=1

# SECRET_KEY=change-for-sessions
# DATABASE_PATH=/path/to/asset_register.sqlite
